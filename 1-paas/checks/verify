# ---------------------------------------------------------------------------
# 6. Cluster capacity
# ---------------------------------------------------------------------------
section "6. Cluster capacity"

eval "$(kubectl describe nodes 2>/dev/null | awk '
function parse_cpu(v) {
  if (v ~ /m$/) { sub(/m$/, "", v); return v+0 }
  return v * 1000
}
function parse_mem(v) {
  if (v ~ /Ki$/) { sub(/Ki$/, "", v); return int(v/1024) }
  if (v ~ /Mi$/) { sub(/Mi$/, "", v); return v+0 }
  if (v ~ /Gi$/) { sub(/Gi$/, "", v); return v*1024 }
  return int(v/1048576)
}
/^Name:/                { in_alloc=0; in_req=0 }
/^Allocatable:/         { in_alloc=1; in_req=0 }
/^Allocated resources:/ { in_alloc=0; in_req=1 }
/^Events:/              { in_req=0 }
in_alloc && /^  cpu:/    { total_alloc_cpu += parse_cpu($2) }
in_alloc && /^  memory:/ { total_alloc_mem += parse_mem($2) }
in_req && /^  cpu /    && $2 ~ /^[0-9]/ { total_req_cpu += parse_cpu($2) }
in_req && /^  memory / && $2 ~ /^[0-9]/ { total_req_mem += parse_mem($2) }
END {
  printf "CAP_ALLOC_CPU=%d CAP_ALLOC_MEM=%d CAP_REQ_CPU=%d CAP_REQ_MEM=%d CAP_AVAIL_CPU=%d CAP_AVAIL_MEM=%d\n",
    total_alloc_cpu, total_alloc_mem, total_req_cpu, total_req_mem,
    total_alloc_cpu - total_req_cpu, total_alloc_mem - total_req_mem
}
')"

printf "  %-12s  %6dm    %6dMi\n" "Allocatable:" "${CAP_ALLOC_CPU}" "${CAP_ALLOC_MEM}"
printf "  %-12s  %6dm    %6dMi\n" "Requested:"   "${CAP_REQ_CPU}"   "${CAP_REQ_MEM}"
printf "  %-12s  %6dm    %6dMi\n" "Available:"   "${CAP_AVAIL_CPU}" "${CAP_AVAIL_MEM}"
echo ""

if [ "${CAP_AVAIL_CPU}" -lt 2000 ]; then
  fail "Less than 2 vCPU available (${CAP_AVAIL_CPU}m) — Istio + sidecars may not schedule"
else
  pass "CPU headroom: ${CAP_AVAIL_CPU}m available"
fi

if [ "${CAP_AVAIL_MEM}" -lt 2048 ]; then
  fail "Less than 2Gi RAM available (${CAP_AVAIL_MEM}Mi) — Istio + sidecars may not schedule"
else
  pass "Memory headroom: ${CAP_AVAIL_MEM}Mi available"
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
echo ""
echo "============================================================"
printf   "  Results: %d passed, %d failed\n" "${PASS}" "${FAIL}"
echo "============================================================"
echo ""

if [ "${FAIL}" -gt 0 ]; then
  echo "Fix the above before continuing"
  echo ""
  exit 1
fi
