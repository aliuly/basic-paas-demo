#!/bin/sh
# ---------------------------------------------------------------------------
# verify — CCE and addons are healthty
#
# Checks that the addons installed by the 1-paas CCE module are healthy.
# A failing APIService (metrics-server, custom-metrics) causes namespace
# deletion to hang cluster-wide — catch this before installing Istio.
#
# Usage:
#   ./run ./preflight
#
# Exits 0 only if all checks pass; use as a gate:
#   HTTPS_PROXY=socks5://localhost:1080 ./preflight && ./install
# ---------------------------------------------------------------------------
set -uf
( set -o pipefail 2>/dev/null ) && set -o pipefail
# Note: no -e — run all checks and report all failures before exiting.

PASS=0
FAIL=0

pass()    { PASS=$((PASS+1)); printf "  PASS  %s\n" "$*"; }
fail()    { FAIL=$((FAIL+1)); printf "  FAIL  %s\n" "$*"; }
warn()    { printf "  WARN  %s\n" "$*"; }
section() { printf "\n==> %s\n" "$*"; }

# ---------------------------------------------------------------------------
# Helper: check an APIService is Available=True
# $1 = APIService name (e.g. v1beta1.metrics.k8s.io)
# $2 = human label
# ---------------------------------------------------------------------------
check_apiservice() {
  NAME="$1"
  LABEL="$2"
  STATUS=$(kubectl get apiservice "$NAME" \
    -o jsonpath='{.status.conditions[?(@.type=="Available")].status}' \
    2>/dev/null || echo "MISSING")
  if [ "${STATUS:-MISSING}" = "True" ]; then
    pass "${LABEL}: Available"
  else
    fail "${LABEL}: not available (${STATUS:-MISSING}) — namespace deletion will hang if this stays False"
    kubectl get apiservice "$NAME" 2>&1 || true
  fi
}

# ---------------------------------------------------------------------------
# 1. Nodes
# ---------------------------------------------------------------------------
section "1. Nodes"

NODE_COUNT=$(kubectl get nodes --no-headers 2>/dev/null | wc -l | tr -d ' ')
NODE_READY=$(kubectl get nodes --no-headers 2>/dev/null | grep -c " Ready ")
NODE_COUNT="${NODE_COUNT:-0}"
NODE_READY="${NODE_READY:-0}"

if [ "${NODE_READY}" -ge 1 ] && [ "${NODE_READY}" = "${NODE_COUNT}" ]; then
  pass "${NODE_READY}/${NODE_COUNT} nodes Ready"
else
  fail "${NODE_READY}/${NODE_COUNT} nodes Ready"
fi
echo ""
kubectl get nodes 2>&1

# ---------------------------------------------------------------------------
# 2. metrics-server
# ---------------------------------------------------------------------------
section "2. metrics-server"

check_apiservice "v1beta1.metrics.k8s.io" "metrics.k8s.io APIService"

METRICS_PODS=$(kubectl get pods -n kube-system --no-headers 2>/dev/null \
  | grep "metrics-server" | grep -c "Running")
if [ "${METRICS_PODS:-0}" -ge 1 ]; then
  pass "metrics-server pod(s) Running: ${METRICS_PODS}"
else
  fail "No metrics-server pods Running in kube-system"
  kubectl get pods -n kube-system 2>/dev/null | grep "metrics-server" || true
fi

# kubectl top proves the APIService is actually serving (not just registered)
if kubectl top nodes >/dev/null 2>&1; then
  pass "kubectl top nodes: responding"
else
  fail "kubectl top nodes: not responding — metrics-server may be unhealthy"
fi

# ---------------------------------------------------------------------------
# 3. cie-collector (monitoring)
# ---------------------------------------------------------------------------
section "3. cie-collector (Prometheus + Grafana)"

check_apiservice "v1beta1.custom.metrics.k8s.io" "custom.metrics.k8s.io APIService"

CIE_TOTAL=$(kubectl get pods -n monitoring --no-headers 2>/dev/null \
  | grep -v "log-agent" | wc -l | tr -d ' ')
CIE_RUNNING=$(kubectl get pods -n monitoring --no-headers 2>/dev/null \
  | grep -v "log-agent" | grep -c "Running")
CIE_TOTAL="${CIE_TOTAL:-0}"
CIE_RUNNING="${CIE_RUNNING:-0}"

if [ "${CIE_RUNNING}" -ge 1 ] && [ "${CIE_RUNNING}" = "${CIE_TOTAL}" ]; then
  pass "cie-collector: ${CIE_RUNNING}/${CIE_TOTAL} pods Running"
else
  fail "cie-collector: ${CIE_RUNNING}/${CIE_TOTAL} pods Running"
  echo ""
  kubectl get pods -n monitoring 2>/dev/null | grep -v "log-agent" || true
  echo ""
  kubectl get pvc -n monitoring 2>&1 || true
fi

