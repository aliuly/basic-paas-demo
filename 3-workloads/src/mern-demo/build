#!/bin/sh
# Builds and pushes the bezkoder-api and bezkoder-ui images to OTC SWR.
#
# Usage:
#   ./build [--registry=REGISTRY] [--tag=TAG]
#
# Defaults:
#   REGISTRY  swr.eu-de.otc.t-systems.com/golden
#   TAG       latest
#
# Prerequisites:
#   docker login swr.eu-de.otc.t-systems.com
#
set -euf
( set -o pipefail 2>/dev/null ) && set -o pipefail

REGISTRY="swr.eu-de.otc.t-systems.com/golden"
TAG="latest"

while [ $# -gt 0 ]
do
  case "$1" in
    --registry=*) REGISTRY="${1#--registry=}" ;;
    --tag=*)      TAG="${1#--tag=}" ;;
    *) echo "Unknown option: $1" 1>&2 ; exit 1 ;;
  esac
  shift
done

MYDIR=$(cd "$(dirname "$0")" && pwd)
DOCKER_CONFIG_FILE="${DOCKER_CONFIG:-$HOME/.docker}/config.json"

# ---------------------------------------------------------------------------
# Check registry credentials before wasting time on the build
# ---------------------------------------------------------------------------
check_registry_auth() {
  local host="$1"

  if [ ! -f "$DOCKER_CONFIG_FILE" ]; then
    echo "ERROR: $DOCKER_CONFIG_FILE not found — run: docker login $host" 1>&2
    exit 1
  fi

  if ! type jq >/dev/null 2>&1; then
    # Fallback: can only check presence, not expiry
    if ! grep -q "$host" "$DOCKER_CONFIG_FILE" 2>/dev/null; then
      echo "ERROR: No credentials found for $host — run: docker login $host" 1>&2
      exit 1
    fi
    echo "NOTE: jq not found — cannot verify credential expiry for $host." 1>&2
    return 0
  fi

  # If a credential helper handles this host, we can't extract the token to test it
  local helper
  helper=$(jq -r --arg h "$host" '.credHelpers[$h] // .credsStore // empty' "$DOCKER_CONFIG_FILE" 2>/dev/null || true)
  if [ -n "$helper" ]; then
    echo "NOTE: Credentials for $host are managed by '$helper' — cannot verify expiry." 1>&2
    return 0
  fi

  local auth
  auth=$(jq -r --arg h "$host" '.auths[$h].auth // empty' "$DOCKER_CONFIG_FILE" 2>/dev/null || true)
  if [ -z "$auth" ]; then
    echo "ERROR: No credentials found for $host — run: docker login $host" 1>&2
    exit 1
  fi
}

REGISTRY_HOST=$(echo "$REGISTRY" | cut -d/ -f1)
check_registry_auth "$REGISTRY_HOST"

# ---------------------------------------------------------------------------
# Build and push
# ---------------------------------------------------------------------------
API_IMAGE="$REGISTRY/mern-api:$TAG"
UI_IMAGE="$REGISTRY/mern-ui:$TAG"

echo "==> Building $API_IMAGE"
docker build -t "$API_IMAGE" "$MYDIR/bezkoder-api"

echo "==> Building $UI_IMAGE"
docker build -t "$UI_IMAGE" "$MYDIR/bezkoder-ui"

echo "==> Pushing $API_IMAGE"
docker push "$API_IMAGE"

echo "==> Pushing $UI_IMAGE"
docker push "$UI_IMAGE"

echo ""
echo "Done."
echo "  $API_IMAGE"
echo "  $UI_IMAGE"
