#!/bin/sh
# ---------------------------------------------------------------------------
# upgrade — canary upgrade of Istio to a new version
#
# Usage:
#   HTTPS_PROXY=socks5://localhost:1080 \
#   ./upgrade --new-version <version> [--ha] [--no-ha]
# ---------------------------------------------------------------------------
set -euf
( set -o pipefail 2>/dev/null ) && set -o pipefail

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
. "${SCRIPT_DIR}/lib"

load_env
set_kubeconfig
check_proxy

NEW_VERSION=""
HA_OVERRIDE=""

while [ $# -gt 0 ]; do
  case "$1" in
    --new-version) NEW_VERSION="$2"; shift 2 ;;
    --new-version=*) NEW_VERSION="${1#--new-version=}"; shift ;;
    --ha)    HA_OVERRIDE=true;  shift ;;
    --no-ha) HA_OVERRIDE=false; shift ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

if [ -z "$NEW_VERSION" ]; then
  echo "Usage: $0 --new-version <version> [--ha|--no-ha]" >&2
  exit 1
fi

if [ -n "$HA_OVERRIDE" ]; then
  ISTIO_HA="$HA_OVERRIDE"
fi

if [ "$ISTIO_HA" = "true" ]; then
  REPLICAS=3
  check_node_count 3
else
  REPLICAS=1
fi

REVISION=$(echo "$NEW_VERSION" | tr '.' '-')

echo "==> Upgrading Istio to ${NEW_VERSION} (revision: ${REVISION}, HA=${ISTIO_HA})"

helm repo update istio

echo "==> Upgrading istio-base to ${NEW_VERSION}"
helm upgrade istio-base istio/base \
  --version "${NEW_VERSION}" \
  --namespace istio-system \
  --values "${SCRIPT_DIR}/istio-base-values.yaml" \
  --wait \
  --timeout 5m

echo "==> Installing istiod revision ${REVISION}"
helm upgrade --install "istiod-${REVISION}" istio/istiod \
  --version "${NEW_VERSION}" \
  --namespace istio-system \
  --values "${SCRIPT_DIR}/istiod-values.yaml" \
  --set pilot.replicaCount="${REPLICAS}" \
  --set revision="${REVISION}" \
  --wait \
  --timeout 5m

echo ""
echo "New control plane is running alongside the old one."
echo ""
echo "Migrate namespaces one at a time:"
echo "  kubectl label namespace <ns> istio.io/rev=${REVISION} istio-injection- --overwrite"
echo "  kubectl rollout restart deployment -n <ns>"
echo ""
echo "Once all namespaces are migrated, run:"
echo "  ./upgrade-complete --old-version ${ISTIO_VERSION}"
