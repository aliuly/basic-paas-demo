#!/bin/sh
# ---------------------------------------------------------------------------
# upgrade-complete — removes old istiod revision after canary upgrade
#
# Usage:
#   HTTPS_PROXY=socks5://localhost:1080 \
#   ./upgrade-complete --old-version <version>
# ---------------------------------------------------------------------------
set -euf
( set -o pipefail 2>/dev/null ) && set -o pipefail

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
. "${SCRIPT_DIR}/lib"

load_env
set_kubeconfig
check_proxy

OLD_VERSION=""

while [ $# -gt 0 ]; do
  case "$1" in
    --old-version) OLD_VERSION="$2"; shift 2 ;;
    --old-version=*) OLD_VERSION="${1#--old-version=}"; shift ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

if [ -z "$OLD_VERSION" ]; then
  echo "Usage: $0 --old-version <version>" >&2
  exit 1
fi

OLD_REVISION=$(echo "$OLD_VERSION" | tr '.' '-')

echo "==> Removing old istiod revision ${OLD_REVISION}"
helm uninstall "istiod-${OLD_REVISION}" --namespace istio-system

echo ""
echo "Old revision removed. Upgrade complete."
echo ""
echo "Re-label migrated namespaces to use the default tag if desired:"
echo "  kubectl label namespace <ns> istio-injection=enabled istio.io/rev- --overwrite"
echo "  kubectl rollout restart deployment -n <ns>"
