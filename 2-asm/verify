#!/bin/sh
# ---------------------------------------------------------------------------
# verify — checks that Istio is correctly installed and functional on OTC CCE
#
# Runs progressive checks from control-plane health through sidecar injection
# and mTLS, printing PASS/FAIL for each so failures can be pinpointed quickly.
#
# Usage:
#   HTTPS_PROXY=socks5://localhost:1080 ./verify
#   ./run ./verify
# ---------------------------------------------------------------------------
set -uf
( set -o pipefail 2>/dev/null ) && set -o pipefail
# Note: no -e — we run all checks and report failures rather than aborting early.

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
. "${SCRIPT_DIR}/lib"

load_env
set_kubeconfig
check_proxy

PASS=0
FAIL=0
SMOKE_NS="istio-smoke-test"

pass()    { PASS=$((PASS+1)); printf "  PASS  %s\n" "$*"; }
fail()    { FAIL=$((FAIL+1)); printf "  FAIL  %s\n" "$*"; }
warn()    { printf "  WARN  %s\n" "$*"; }
section() { printf "\n==> %s\n" "$*"; }

cleanup_smoke() {
  kubectl delete namespace "$SMOKE_NS" --ignore-not-found --wait=false >/dev/null 2>&1 || true
}
trap cleanup_smoke EXIT

# ---------------------------------------------------------------------------
# 1. Control plane
# ---------------------------------------------------------------------------
section "1. Control plane"

ISTIOD_DESIRED=$(kubectl get deployment istiod -n istio-system \
  -o jsonpath='{.spec.replicas}' 2>/dev/null || echo "0")
ISTIOD_READY=$(kubectl get deployment istiod -n istio-system \
  -o jsonpath='{.status.readyReplicas}' 2>/dev/null || echo "0")
ISTIOD_DESIRED="${ISTIOD_DESIRED:-0}"
ISTIOD_READY="${ISTIOD_READY:-0}"

if [ "${ISTIOD_READY}" -ge 1 ] && [ "${ISTIOD_READY}" = "${ISTIOD_DESIRED}" ]; then
  pass "istiod: ${ISTIOD_READY}/${ISTIOD_DESIRED} replicas ready"
else
  fail "istiod: ${ISTIOD_READY}/${ISTIOD_DESIRED} replicas ready"
fi
echo ""
kubectl get pods -n istio-system 2>&1

# ---------------------------------------------------------------------------
# 2. CRDs
# ---------------------------------------------------------------------------
section "2. CRDs"

CRD_COUNT=$(kubectl get crd 2>/dev/null | grep -c "istio.io")
if [ "${CRD_COUNT:-0}" -ge 14 ]; then
  pass "${CRD_COUNT} Istio CRDs present"
else
  fail "Expected >=14 Istio CRDs, found ${CRD_COUNT:-0}"
  kubectl get crd 2>/dev/null | grep "istio.io" || true
fi

# ---------------------------------------------------------------------------
# 3. PeerAuthentication policies
# ---------------------------------------------------------------------------
section "3. PeerAuthentication policies"

echo ""
kubectl get peerauthentication -A 2>&1
echo ""

for ns_mode in "istio-system:STRICT" "kube-system:PERMISSIVE" "monitoring:PERMISSIVE"; do
  NS="${ns_mode%%:*}"
  EXPECTED="${ns_mode##*:}"
  ACTUAL=$(kubectl get peerauthentication default -n "$NS" \
    -o jsonpath='{.spec.mtls.mode}' 2>/dev/null || echo "MISSING")
  if [ "${ACTUAL:-MISSING}" = "$EXPECTED" ]; then
    pass "${NS}/default: ${ACTUAL}"
  else
    fail "${NS}/default: expected ${EXPECTED}, got ${ACTUAL:-MISSING}"
  fi
done

# ---------------------------------------------------------------------------
# 4. Mutating webhook
# ---------------------------------------------------------------------------
section "4. Mutating webhook"

WEBHOOK_COUNT=$(kubectl get mutatingwebhookconfiguration istio-sidecar-injector \
  -o jsonpath='{range .webhooks[*]}{.name}{"\n"}{end}' 2>/dev/null \
  | wc -l | tr -d ' ')
WEBHOOK_COUNT="${WEBHOOK_COUNT:-0}"

WEBHOOK_BAD=0
i=0
while [ "$i" -lt "$WEBHOOK_COUNT" ]; do
  URL=$(kubectl get mutatingwebhookconfiguration istio-sidecar-injector \
    -o jsonpath="{.webhooks[${i}].clientConfig.url}" 2>/dev/null || echo "")
  SVC=$(kubectl get mutatingwebhookconfiguration istio-sidecar-injector \
    -o jsonpath="{.webhooks[${i}].clientConfig.service.name}" 2>/dev/null || echo "")
  if echo "${URL:-}" | grep -q "30017"; then
    pass "Webhook ${i}: NodePort ${URL}"
  elif [ -n "${SVC:-}" ]; then
    fail "Webhook ${i}: still points to ClusterIP service '${SVC}' — re-run ./install to patch"
    WEBHOOK_BAD=$((WEBHOOK_BAD+1))
  else
    fail "Webhook ${i}: unexpected config — url='${URL:-empty}' service='${SVC:-empty}'"
    WEBHOOK_BAD=$((WEBHOOK_BAD+1))
  fi
  i=$((i+1))
done

# ---------------------------------------------------------------------------
# 5. Sidecar injection (smoke test)
# ---------------------------------------------------------------------------
section "5. Sidecar injection"

# A previous run's EXIT trap may still be draining the namespace.
while kubectl get namespace "$SMOKE_NS" 2>/dev/null | grep -q Terminating; do
  echo "     Waiting for previous smoke namespace to finish terminating..."
  sleep 2
done
kubectl get namespace "$SMOKE_NS" >/dev/null 2>&1 \
  || kubectl create namespace "$SMOKE_NS" >/dev/null
kubectl label namespace "$SMOKE_NS" istio-injection=enabled --overwrite >/dev/null

kubectl delete pod smoke -n "$SMOKE_NS" --ignore-not-found >/dev/null 2>&1
if kubectl run smoke -n "$SMOKE_NS" --image=curlimages/curl \
     --restart=Never -- sleep 300 >/dev/null; then
  echo "     Waiting for smoke pod to be ready (up to 90s)..."
  kubectl wait pod/smoke -n "$SMOKE_NS" --for=condition=Ready --timeout=90s \
    >/dev/null 2>&1 || true
else
  echo "     Pod creation failed (webhook error?) — skipping wait"
fi

CONTAINER_COUNT=$(kubectl get pod smoke -n "$SMOKE_NS" \
  -o jsonpath='{range .spec.containers[*]}{.name}{"\n"}{end}' 2>/dev/null \
  | wc -l | tr -d ' ')
CONTAINER_COUNT="${CONTAINER_COUNT:-0}"

if [ "${CONTAINER_COUNT}" -ge 2 ]; then
  pass "Sidecar injected — pod has ${CONTAINER_COUNT} containers"
else
  fail "Sidecar NOT injected — pod has ${CONTAINER_COUNT} container(s)"
  echo ""
  kubectl describe pod smoke -n "$SMOKE_NS" 2>&1
fi

# ---------------------------------------------------------------------------
# 6. Envoy liveness
# ---------------------------------------------------------------------------
section "6. Envoy liveness"

if [ "${CONTAINER_COUNT}" -ge 2 ]; then
  ENVOY_INFO=$(kubectl exec smoke -n "$SMOKE_NS" -c istio-proxy \
    -- curl -s http://localhost:15000/server_info 2>/dev/null || echo "")
  ENVOY_STATE=$(echo "${ENVOY_INFO}" | grep -o '"state":"[^"]*"' | head -1 || echo "")

  if echo "${ENVOY_STATE:-}" | grep -q "LIVE"; then
    pass "Envoy state: LIVE"
  else
    fail "Envoy state unexpected: ${ENVOY_STATE:-unable to reach admin API}"
    echo ""
    echo "${ENVOY_INFO}" | head -20
  fi
else
  warn "Skipped — no sidecar container (step 5 failed)"
fi

# ---------------------------------------------------------------------------
# 7. mTLS identity (SPIFFE cert)
# ---------------------------------------------------------------------------
section "7. mTLS identity"

if [ "${CONTAINER_COUNT}" -ge 2 ]; then
  SPIFFE=$(kubectl exec smoke -n "$SMOKE_NS" -c istio-proxy \
    -- curl -s http://localhost:15000/certs 2>/dev/null \
    | grep -o '"uri":"spiffe://[^"]*"' | head -1 || echo "")

  if [ -n "${SPIFFE:-}" ]; then
    pass "SPIFFE identity: ${SPIFFE}"
  else
    fail "No SPIFFE URI in Envoy certs — mTLS identity not established"
    echo ""
    kubectl exec smoke -n "$SMOKE_NS" -c istio-proxy \
      -- curl -s http://localhost:15000/certs 2>&1 | head -40 || true
  fi
else
  warn "Skipped — no sidecar container (step 5 failed)"
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
echo ""
echo "============================================================"
printf   "  Results: %d passed, %d failed\n" "${PASS}" "${FAIL}"
echo "============================================================"
echo ""

[ "${FAIL}" -eq 0 ]
